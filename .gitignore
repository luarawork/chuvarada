# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# next-pwa build artifacts
/public/sw.js
/public/workbox-*.js
/public/fallback-*.js

# dados geoespaciais brutos: versionamos o que cabe no limite de 100MB do
# GitHub (ver scripts/ para os comandos de download originais). Fora disso:
# - geopackage nacional da BHO (2.7GB) — baixar via scripts/process_bho.py
# - hydro_nordeste_clipped.geojson (141MB) — cache intermediário, regenerado
#   automaticamente ao rodar process_bho.py/process_hydro_recife.py
/dados-brutos/ana/geoft_bho_curso_dagua.gpkg
/dados-brutos/ana/hydro_nordeste_clipped.geojson

# SRTM estadual (BA/PE/RN inteiros) — passam de 100MB fácil (Bahia mesclada
# dá ~900MB). Recriáveis via os comandos wget da tarefa de expansão estadual.
# Os SRTM por cidade (salvador/recife/natal/etc, pequenos) continuam versionados.
/dados-brutos/srtm/srtm_bahia.tif
/dados-brutos/srtm/srtm_bahia_sw.tif
/dados-brutos/srtm/srtm_bahia_se.tif
/dados-brutos/srtm/srtm_bahia_nw.tif
/dados-brutos/srtm/srtm_bahia_ne.tif
/dados-brutos/srtm/srtm_pernambuco.tif
/dados-brutos/srtm/srtm_rn.tif
/dados-brutos/srtm/srtm_alagoas.tif
/dados-brutos/srtm/srtm_ceara.tif
/dados-brutos/srtm/srtm_maranhao.tif
/dados-brutos/srtm/srtm_paraiba.tif
/dados-brutos/srtm/srtm_piaui.tif
/dados-brutos/srtm/srtm_sergipe.tif

# SRTM Sul + Sudeste (expansão nacional, 21/07/2026) — mesmo motivo acima.
# MG/RS/SP passaram do limite de área da API do OpenTopography (450.000km²)
# e foram baixados em quadrantes/metades e mesclados com rasterio.
/dados-brutos/srtm/srtm_parana.tif
/dados-brutos/srtm/srtm_santa_catarina.tif
/dados-brutos/srtm/srtm_rio_grande_do_sul.tif
/dados-brutos/srtm/srtm_sao_paulo.tif
/dados-brutos/srtm/srtm_rio_de_janeiro.tif
/dados-brutos/srtm/srtm_minas_gerais.tif
/dados-brutos/srtm/srtm_espirito_santo.tif

# zips do IBGE e do S2ID já descompactados (redundantes com os arquivos versionados)
/dados-brutos/ibge/*/*.zip

# Shapefiles de setores censitários do IBGE que passam do limite de 100MB do
# GitHub em pelo menos um arquivo (MG_setores.shp 155MB, SC_setores.shp
# 110MB, SP_setores.shp 132MB + SP_setores.dbf 218MB) — PR/RJ/RS/ES ficam
# todos abaixo do limite e continuam versionados normalmente. Recriáveis via
# os comandos de download da tarefa de expansão Sul+Sudeste.
/dados-brutos/ibge/mg/
/dados-brutos/ibge/sc/
/dados-brutos/ibge/sp/
/dados-brutos/S2ID/*.zip

# ZIPs anuais do INMET (Brasil inteiro, ~80-100MB cada) — só os CSVs das 3
# estações (Salvador/Recife/Natal) já extraídos ficam versionados.
/dados-brutos/inmet/*.zip

# cache de bytecode Python
__pycache__/
*.pyc
